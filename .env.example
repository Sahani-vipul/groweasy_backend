MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
JWT_SECRET=<a long random string, auto-generated if omitted>
AI_PROVIDER=nvidia
NVIDIA_API_KEY=<your key from build.nvidia.com, format nvapi-...>
NVIDIA_MODEL=openai/gpt-oss-120b
ANTHROPIC_API_KEY=<your key, if using anthropic>
OPENAI_API_KEY=<your key, if using openai>
GEMINI_API_KEY=<your key, if using gemini>
GROK_API_KEY=<your key, if using grok>
PORT=4000
FRONTEND_URL=http://localhost:3000
